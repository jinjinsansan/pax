# PAXG/XAUT Arbitrage Monitor — 環境変数テンプレート
# 実際の値は .env.local（gitignore済み）に置く。このファイルに実値を書かない。

NODE_ENV=development
CHAIN_ID=1
PHASE=1

# Ethereum RPC（Primary/Secondary、HTTP+WebSocket）
ETH_RPC_HTTP_PRIMARY=
ETH_RPC_WS_PRIMARY=
ETH_RPC_HTTP_SECONDARY=
ETH_RPC_WS_SECONDARY=

# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Worker識別・リース
WORKER_ID=local-dev-01
WORKER_ROLE=primary
LEASE_NAME=ethereum-arbitrage-monitor
LEASE_TTL_SECONDS=45

# 閾値（arb.system_configで上書き可能な初期値）
REFERENCE_ALERT_PCT=0.50
EXECUTABLE_ALERT_PCT=0.50
MIN_NET_PROFIT_USD=25
MIN_NET_PROFIT_PCT=0.10
MAX_PRICE_IMPACT_PCT=0.30
ALERT_COOLDOWN_SECONDS=300

# Internal API
INTERNAL_API_HMAC_SECRET=

# ===== Phase 1/2 安全ガード =====
# TRADING_ENABLEDはfalse固定。PRIVATE_KEYが設定されていたら起動失敗する（仕様書§18）。
TRADING_ENABLED=false
PRIVATE_KEY=
